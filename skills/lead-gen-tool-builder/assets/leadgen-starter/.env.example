# ─────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in your OWN API credentials.
# `.env` is gitignored — never commit real keys.
# ─────────────────────────────────────────────────────────────

# Explorium — the data provider that powers search/enrichment.
# Get an API key: https://developers.explorium.ai/  (Dashboard → API Keys)
EXPLORIUM_API_KEY=

# HubSpot — private-app access token (optional; needed for HubSpot push).
# HubSpot → Settings → Integrations → Private Apps → create app → copy token.
# Scopes: crm.objects.contacts.write, crm.objects.companies.write
HUBSPOT_API_KEY=

# Salesforce — Connected App using the JWT Bearer flow (optional; needed for
# Salesforce push). See README "Salesforce setup" for how to create these.
SALESFORCE_CONSUMER_KEY=
SALESFORCE_USERNAME=
SALESFORCE_LOGIN_URL=https://login.salesforce.com
# The Connected App's private key, base64-encoded:
#   base64 -i server.key    (macOS/Linux)  ->  paste the single-line output here
SALESFORCE_PRIVATE_KEY_BASE64=

# Backend port (frontend dev server proxies /api here).
PORT=4000
